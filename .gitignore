# ========================
# Trendora Server .gitignore
# ========================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so

# --- Virtual Environments ---
venv/
.venv/
env/
ENV/

# --- Environment Variables (SECRETS) ---
.env
.env.*
!.env.example

# --- IDE ---
.vscode/
.idea/
.cursor/
*.swp
*.swo

# --- Testing ---
.pytest_cache/
.hypothesis/
htmlcov/
.coverage
coverage.xml

# --- Logs & Debug Output ---
*.log
*.txt
!requirements.txt
!runtime.txt
*.json
!package.json

# --- OS ---
.DS_Store
Thumbs.db

# --- Distribution ---
dist/
build/
*.egg-info/
*.egg

# --- Docker ---
.dockerignore
